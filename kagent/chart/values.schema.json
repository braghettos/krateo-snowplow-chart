{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "krateo-snowplow-agent values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "namespace": {
      "type": "string"
    },
    "modelConfig": {
      "type": "object",
      "additionalProperties": false,
      "description": "ModelConfig the agent uses \u2014 referenced by name, or created here (create=true) so this agent's model/provider is configured independently.",
      "properties": {
        "name": {
          "type": "string"
        },
        "create": {
          "type": "boolean"
        },
        "provider": {
          "type": "string",
          "enum": [
            "Anthropic",
            "OpenAI",
            "AzureOpenAI",
            "Ollama",
            "Gemini",
            "GeminiVertexAI",
            "AnthropicVertexAI",
            "Bedrock",
            "SAPAICore"
          ]
        },
        "model": {
          "type": "string"
        },
        "vertexAI": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "projectID": {
              "type": "string"
            },
            "location": {
              "type": "string"
            }
          }
        },
        "apiKeySecret": {
          "type": "string"
        },
        "apiKeySecretKey": {
          "type": "string"
        }
      }
    },
    "prompts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "language": {
          "type": "string"
        }
      }
    },
    "vertexAI": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "projectID": {
          "type": "string"
        },
        "location": {
          "type": "string"
        }
      }
    },
    "github": {
      "type": "object",
      "additionalProperties": false,
      "description": "github MCP server the agent uses to read its component's codebase + chart.",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "mcpServer": {
          "type": "string"
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": true
    },
    "global": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
